{
  "title": "CogLoad Serving",
  "uid": "cogload-serving",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Throughput — requests / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(eep_requests_total[1m])",
          "legendFormat": "EEP {{endpoint}} {{status}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(iep1_requests_total[1m])",
          "legendFormat": "IEP-1 {{status}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(iep2_requests_total[1m])",
          "legendFormat": "IEP-2 {{status}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(eep_requests_total{status=\"error\"}[1m]) / (rate(eep_requests_total[1m]) > 0)",
          "legendFormat": "EEP",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(iep1_requests_total{status=\"error\"}[1m]) / (rate(iep1_requests_total[1m]) > 0)",
          "legendFormat": "IEP-1",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(iep2_requests_total{status=\"error\"}[1m]) / (rate(iep2_requests_total[1m]) > 0)",
          "legendFormat": "IEP-2",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "EEP Latency — p50 / p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(eep_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(eep_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "IEP-1 Latency — p50 / p95",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 7, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(iep1_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(iep1_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "IEP-2 Latency — p50 / p95",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 7, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(iep2_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(iep2_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Prediction Confidence Distribution (ML signal)",
      "description": "Histogram bucket rates of ensemble output probabilities. Spikes near le=0.1 and le=1.0 indicate a confident, bimodal model.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(iep1_prediction_confidence_bucket[5m])",
          "legendFormat": "le={{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Input Drift Score — mean |z| (ML signal)",
      "description": "p50/p95 of mean |z-score| across normalized features per request. Near 1 = calibration fresh. > 2 = stale calibration or signal shift.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(iep1_input_drift_score_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(iep1_input_drift_score_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Uncalibrated Requests (last 5 min)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 14, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(iep1_uncalibrated_requests_total[5m])",
          "legendFormat": "uncalibrated",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Downstream Errors (EEP → IEP)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(eep_downstream_errors_total[1m])",
          "legendFormat": "{{iep}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "IEP-2 Windows Used per Calibration (p50)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(iep2_windows_used_bucket[5m]))",
          "legendFormat": "p50 windows",
          "refId": "A"
        }
      ]
    }
  ]
}
